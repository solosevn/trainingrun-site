# ──────────────────────────────────────────────────────────
# Daily News Agent — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to GitHub (it's in .gitignore).
# ──────────────────────────────────────────────────────────

# Telegram — Daily News Bot (@TRnewzBot)
TRNEWZ_BOT_TOKEN=your_daily_news_bot_token_here
DAVID_CHAT_ID=your_telegram_user_id_here

# xAI — Grok API (same key as Content Scout)
XAI_API_KEY=your_xai_api_key_here

# GitHub — Personal Access Token (scope: repo)
GITHUB_TOKEN=your_github_pat_here

# Paths — adjust if your repo is elsewhere
TR_REPO_PATH=/Users/davidsolomon/trainingrun-site
